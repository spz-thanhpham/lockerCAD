# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# PostgreSQL — local install on Windows
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/locker_tool"

# NextAuth — generate secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave blank to skip)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
