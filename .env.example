# Copy this file to .env.local (local dev) or set these in your server/Vercel env
# NEVER commit .env.local to git

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/locker_tool"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-generated-secret"
# Must exactly match the URL users visit (no trailing slash)
# Local:      http://localhost:3333
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3333"

# ── Admin credentials login ──────────────────────────────────────────────────
# These are required for the email+password login to work.
# Use a strong password in production.
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="change-this-strong-password"

# ── Microsoft / Office 365 SSO (recommended for company use) ──────────────
# Setup steps:
#   1. Go to https://portal.azure.com → Azure Active Directory → App registrations
#   2. Click "New registration"
#      - Name: LockerCAD (or anything)
#      - Supported account types:
#          "Accounts in this organizational directory only" → single-tenant (recommended)
#          "Accounts in any organizational directory"      → multi-tenant
#      - Redirect URI: Web → http://localhost:3333/api/auth/callback/azure-ad
#        (change to your production URL when deploying)
#   3. After creation, copy the Application (client) ID → AZURE_AD_CLIENT_ID
#   4. Copy the Directory (tenant) ID            → AZURE_AD_TENANT_ID
#   5. Go to "Certificates & secrets" → New client secret → copy value → AZURE_AD_CLIENT_SECRET
#   6. (Optional) Under "API permissions" add: Microsoft Graph → User.Read (already default)
#
# Leave all three blank to hide the Microsoft button on the sign-in page.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""   # your-tenant-id  OR  "common" for any Microsoft account

# ── Google OAuth (optional — leave blank to skip) ──────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
